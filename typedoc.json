{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": ["src/index.ts"],
	"gitRemote": "codeberg",
	"sourceLinkTemplate": "https://codeberg.org/thi.ng/umbrella/src/commit/{gitRevision}/{path}#L{line}",
	"excludeInternal": true,
	"excludePrivate": true,
	"highlightLanguages": [
		"bash",
		"bibtex",
		"c",
		"css",
		"glsl",
		"html",
		"js",
		"json",
		"jsonc",
		"json5",
		"ts",
		"wasm",
		"xml",
		"zig"
	]
}
